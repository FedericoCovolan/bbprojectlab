<script>
const ch = { c: null, f: null, b: null };

// Variazioni di bianco per i tessuti
const FC = {
  cotone:  ['#FFFFFF','#F2F2F2','#E6E6E6'],
  raso:    ['#FDFBFF','#F4EEFF','#EBE0FF'],
  velluto: ['#F9F6F0','#F0EBE1','#E6DED0'],
  pizzo:   ['#FFFAFC','#FFF0F5','#FFE6EE']
};

const BC = {
  oro:     [['#FFE87A','#C8900A'],['#FFE87A','#C8900A'],['#FFE87A','#C8900A'],['#FFE87A','#C8900A'],['#FFE87A','#C8900A']],
  argento: [['#F0F0F0','#909090'],['#F0F0F0','#909090'],['#F0F0F0','#909090'],['#F0F0F0','#909090'],['#F0F0F0','#909090']],
  rosa:    [['#FFB3D1','#E0508A'],['#FFB3D1','#E0508A'],['#FFB3D1','#E0508A'],['#FFB3D1','#E0508A'],['#FFB3D1','#E0508A']],
  multi:   [['#FF6B6B','#CC2020'],['#FFD93D','#CC8800'],['#6BCB77','#228830'],['#4D96FF','#1050CC'],['#C77DFF','#7020CC']]
};

const Nomi = {
  c: { tshirt: 'T-shirt', canotta: 'Canotta', bretelle: 'Top' },
  f: { cotone: 'Cotone', raso: 'Raso', velluto: 'Velluto', pizzo: 'Pizzo' },
  b: { oro: 'Gold', argento: 'Silver', rosa: 'Pink', multi: 'Pop' }
};

function pick(type, val, el) {
  ch[type] = val;
  el.closest('.screen').querySelectorAll('.opt-card').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  document.getElementById('b' + type).classList.add('show');
}

function go(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

function showResult() {
  if (!ch.c || !ch.f || !ch.b) return;
  const fc = FC[ch.f];
  const bc = BC[ch.b];
  const bx = [68,84,100,116,132];
  
  // Perline
  const defs = bc.map((c,i) => `<linearGradient id="g${i}" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="${c[0]}"/><stop offset="100%" stop-color="${c[1]}"/></linearGradient>`).join('');
  const beads = bc.map((c,i) => `<circle cx="${bx[i]}" cy="160" r="6.5" fill="url(#g${i})" stroke="rgba(0,0,0,0.1)" stroke-width="1.2"/>`).join('');
  
  let svgShape = '';
  
  // Disegna il capo giusto
  if (ch.c === 'tshirt') {
    svgShape = `
      <polygon points="36,60 4,16 0,66 36,88" fill="${fc[1]}"/>
      <polygon points="164,60 196,16 200,66 164,88" fill="${fc[1]}"/>
      <rect x="36" y="60" width="128" height="157" rx="6" fill="${fc[0]}"/>
      <path d="M68,60 Q100,80 132,60" fill="none" stroke="${fc[2]}" stroke-width="2"/>
    `;
  } else if (ch.c === 'canotta') {
    svgShape = `
      <path d="M50,20 L74,20 L74,60 L50,60 Z" fill="${fc[1]}"/>
      <path d="M126,20 L150,20 L150,60 L126,60 Z" fill="${fc[1]}"/>
      <rect x="36" y="60" width="128" height="157" rx="6" fill="${fc[0]}"/>
      <path d="M74,60 Q100,90 126,60" fill="none" stroke="${fc[2]}" stroke-width="2"/>
      <g stroke="${fc[2]}" stroke-width="1" opacity="0.4">
        <line x1="56" y1="70" x2="56" y2="217"/>
        <line x1="76" y1="70" x2="76" y2="217"/>
        <line x1="96" y1="70" x2="96" y2="217"/>
        <line x1="116" y1="70" x2="116" y2="217"/>
        <line x1="136" y1="70" x2="136" y2="217"/>
      </g>
    `;
  } else if (ch.c === 'bretelle') {
    svgShape = `
      <line x1="60" y1="10" x2="60" y2="60" stroke="${fc[1]}" stroke-width="6"/>
      <line x1="140" y1="10" x2="140" y2="60" stroke="${fc[1]}" stroke-width="6"/>
      <rect x="36" y="60" width="128" height="157" rx="6" fill="${fc[0]}"/>
      <line x1="36" y1="60" x2="164" y2="60" stroke="${fc[2]}" stroke-width="2"/>
    `;
  }

  // Componi l'SVG
  document.getElementById('rt').innerHTML = `
    <svg width="100%" height="100%" viewBox="0 0 200 225" xmlns="http://www.w3.org/2000/svg">
      <defs>${defs}</defs>
      ${svgShape}
      <text x="100" y="148" text-anchor="middle" font-size="40" fill="rgba(232,25,60,0.09)">★</text>
      ${beads}
    </svg>`;
    
  // Crea il nome finale (es. "T-SHIRT COTONE GOLD ★")
  document.getElementById('rn').textContent = `${Nomi.c[ch.c]} ${Nomi.f[ch.f]} ${Nomi.b[ch.b]} ★`.toUpperCase();
  go('s4');
}

function restart() {
  ch.c = null; ch.f = null; ch.b = null;
  document.querySelectorAll('.opt-card').forEach(o => o.classList.remove('selected'));
  ['bc','bf','bb'].forEach(id => document.getElementById(id).classList.remove('show'));
  go('s0');
}
</script>
