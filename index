<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#E8193C">
<title>BB Project Lab</title>
<style>
  :root { --red: #E8193C; --white: #FFFFFF; --pink: #FF69B4; }
  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

  html, body {
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: var(--red);
    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif;
    touch-action: manipulation;
  }

  .screen {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: none;
    flex-direction: column;
    background: var(--red);
    overflow-y: auto;
    overflow-x: hidden;
    -webkit-overflow-scrolling: touch;
  }
  .screen.active { display: flex; }

  .screen-inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: max(52px, env(safe-area-inset-top)) 24px max(32px, env(safe-area-inset-bottom));
    min-height: 100%;
  }

  .big-title {
    font-size: clamp(40px, 12vw, 62px);
    font-weight: 900;
    color: var(--white);
    text-align: left;
    line-height: 0.92;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    width: 100%;
    margin-bottom: 4px;
  }
  .big-title em { font-style: normal; color: rgba(255,255,255,0.4); }

  .tshirt-area {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 180px;
  }

  .bottom-area {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    padding-top: 4px;
  }

  .dots { display: flex; gap: 8px; justify-content: center; }
  .dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.25);
    transition: all 0.25s;
  }
  .dot.done { background: rgba(255,255,255,0.65); }
  .dot.active { background: var(--pink); width: 22px; border-radius: 4px; }

  .cta-btn {
    width: 100%;
    padding: 20px;
    border-radius: 16px;
    border: none;
    background: var(--white);
    color: var(--red);
    font-size: 16px;
    font-weight: 900;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: transform 0.12s;
    opacity: 0;
    pointer-events: none;
    min-height: 60px;
  }
  .cta-btn.show, .cta-btn.always { opacity: 1; pointer-events: all; }
  .cta-btn:active { transform: scale(0.97); }
  .cta-btn.ghost {
    background: rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.75);
    border: 2px solid rgba(255,255,255,0.3);
  }

  .options-wrap {
    width: 100%;
    flex: 1;
    display: flex;
    align-items: center;
    padding: 16px 0;
  }

  .options-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    width: 100%;
  }

  .options-grid.three-cols {
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }

  .opt-card {
    background: rgba(255,255,255,0.1);
    border: 2px solid transparent;
    border-radius: 18px;
    padding: 18px 6px 14px;
    cursor: pointer;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    min-height: 118px;
    justify-content: center;
    user-select: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .opt-card:active { transform: scale(0.95); }
  .opt-card.selected { border-color: var(--white); background: rgba(255,255,255,0.18); }

  .opt-label { font-size: 13px; font-weight: 800; color: var(--white); text-transform: uppercase; letter-spacing: 0.05em; }
  .opt-sub { font-size: 10px; color: rgba(255,255,255,0.5); letter-spacing: 0.02em; }

  .swatch { width: 54px; height: 54px; border-radius: 13px; overflow: hidden; border: 1.5px solid rgba(255,255,255,0.18); display: flex; align-items: center; justify-content: center; }
  
  .swatch.no-border { border: none; background: transparent; }

  .bead-row { display: flex; gap: 5px; align-items: center; justify-content: center; height: 54px; }
  .bead { width: 15px; height: 15px; border-radius: 50%; border: 1.5px solid rgba(255,255,255,0.3); flex-shrink: 0; }

  .res-name { font-size: 13px; font-weight: 700; color: rgba(255,255,255,0.55); text-transform: uppercase; letter-spacing: 0.12em; text-align: center; margin-top: 8px; }
  .share-hint { font-size: 11px; color: rgba(255,255,255,0.3); letter-spacing: 0.06em; text-transform: uppercase; }

  @keyframes up { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }
  .screen.active .screen-inner { animation: up 0.28s ease; }
</style>
</head>
